# Esiana Docker Compose environment
# Pair with compose.docker.example.yml → docker-compose.yml
# Optional overrides: options/environment-variables.md
#
# Generate JWT_SECRET:     openssl rand -hex 32
# Generate AUTH_SECRETS_KEY (OIDC, production): openssl rand -base64 32

# --- Required ---
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me-use-openssl-rand-hex-32

# --- Optional ---
# ESIANA_VERSION=v1.0.7
# COMPOSE_HTTP_PORT=8080
#
# Public URL users type in the browser (no trailing slash).
# Single source of truth — compose derives origin-related app vars at startup.
# PUBLIC_ORIGIN=https://esiana.example.com
#
# HTTPS behind a reverse proxy:
# TRUST_PROXY=true
# COOKIE_SECURE=true
#
# OIDC (Admin -> Identity Providers) — required in production to encrypt stored IdP secrets:
# AUTH_SECRETS_KEY=
#
# OPENAPI_DOCS_ENABLED=false