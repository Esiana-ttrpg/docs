# Esiana Docker Compose environment
# Copy to .env beside docker-compose.yml before: docker compose up -d --build
#
# Generate JWT_SECRET: openssl rand -hex 32
# Generate AUTH_SECRETS_KEY (OIDC): openssl rand -base64 32

# --- Required (production) ---
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Public URL users type in the browser (no trailing slash)
PUBLIC_ORIGIN=http://localhost:8080

# Derived for backend — usually same as PUBLIC_ORIGIN
CORS_ORIGIN=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:8080
BACKEND_PUBLIC_ORIGIN=http://localhost:8080

# Required when using Admin → Identity Providers in production
# AUTH_SECRETS_KEY=

# PostgreSQL credentials (Compose postgres service)
POSTGRES_USER=esiana
POSTGRES_PASSWORD=change-me
POSTGRES_DB=esiana

# --- Optional overrides ---
# ESIANA_VERSION=v1.0.1
# COMPOSE_HTTP_PORT=8080
# OPENAPI_DOCS_ENABLED=true
